# === Database ===
# PostgreSQL (Prisma). Формат: postgresql://user:password@host:port/dbname?sslmode=require
# В проде: sslmode=verify-full + ограниченный пользователь (не владелец БД), IP allowlist на стороне провайдера.
DATABASE_URL=

# === Server ===
PORT=3001
# Корневой URL фронтенда (для CORS и email-ссылок). Без завершающего слэша.
APP_BASE_URL=http://localhost:5173
# В production обязательно задать NODE_ENV=production на хосте.
# NODE_ENV=production

# === JWT ===
# Сгенерируйте надёжные случайные строки (например: openssl rand -base64 48).
# В production сервер не запустится, если значения отсутствуют или короче 16 символов.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# === Cookies ===
# По умолчанию в prod: SameSite=None + Secure (кросс-origin SPA+API).
# Для dev можно оставить пустыми.
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# === Yandex OAuth ===
# Создать в https://oauth.yandex.ru/, redirect URI должен совпадать с YANDEX_REDIRECT_URI.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3001/api/auth/yandex/callback

# === Email provider ===
# resend | smtp
EMAIL_PROVIDER=resend
# Для resend
RESEND_API_KEY=
EMAIL_FROM=Nodly <onboarding@resend.dev>
# Для smtp (используется, если EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# В dev: если провайдер не сконфигурирован, письма логируются в stdout.
EMAIL_DEV_LOG=true

# === Регистрация / сброс пароля ===
REGISTRATION_OTP_TTL_MIN=15
PASSWORD_RESET_TTL_MIN=60

# === Frontend (Vite) ===
# В корне фронтенда (vite читает .env.* в корне проекта).
VITE_API_BASE_URL=http://localhost:3001
VITE_CONTACT_EMAIL=
